<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Driver app reaches bus control over LAN HTTP (192.168.x.x:5174). -->
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
