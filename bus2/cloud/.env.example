# Railway / production — set in Railway → Service → Variables

NODE_ENV=production

# Domains (both serve the same cloud admin)
ADKERALA_PUBLIC_URL=https://adkerala.com
ADKERALA_ALT_URLS=https://adkeralav1-production.up.railway.app

# Optional: share session across subdomains of adkerala.com (e.g. www)
# ADKERALA_COOKIE_DOMAIN=.adkerala.com

# Auth (required)
ADKERALA_JWT_SECRET=change-me-long-random-string
ADKERALA_ADMIN_KEY=change-me-long-random-string
ADKERALA_BOOTSTRAP_ADMIN_EMAIL=admin@adkerala.com
ADKERALA_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Persistence (attach Railway Volume at /data)
DATA_DIR=/data

# Optional
# ADKERALA_BUS_KEY=
# DATABASE_URL=postgres://...
# VITE_CLOUD_URL=https://adkerala.com

# Railway sets PORT automatically — do not override.
